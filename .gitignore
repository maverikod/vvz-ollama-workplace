.venv/
.env
secrets.env
*.local.json
# Local config with API keys — never commit
config/adapter_config.local.json
config/model_workspace_server_config.json
# Generated config (may contain API keys from env)
config/adapter_config.generated.json
config/*_config.generated.json
# Runtime logs (may contain API key fragments)
logs/
__pycache__/
*.egg-info/

# Docker runtime dirs (generated config, certs, logs, cache, data)
docker/config/
docker/logs/
docker/cache/
docker/data/
docker/certs/

# mTLS generated (keep generate_certs.sh and README)
mtls_certificates/

docker/data-db/blobs/
docker/data-mws/blobs/