    "protocol": "mtls",
    "servername": "ollama-server",
    "ssl": {
      "cert": "/app/certs/server.crt",
      "key": "/app/certs/server.key",
      "ca": "/app/certs/ca.crt",
      "crl": null,
      "dnscheck": false,
      "check_hostname": null
    },
    "rules": null,
